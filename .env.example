# Core database and Supabase
DATABASE_URL=
# Direct Postgres or Supabase session-pooler URL for migrations (port 5432).
DIRECT_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_PACTA_DEFAULT_CUSTOMER_PHONE=
# Comma-separated, maximum three numbers in E.164 format.
NEXT_PUBLIC_PACTA_DEFAULT_SUPPLIER_PHONES=
SUPABASE_SECRET_KEY=
SUPABASE_STORAGE_BUCKET=pacta-private

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_CUSTOMER_AGENT_ID=
ELEVENLABS_SUPPLIER_AGENT_ID=
ELEVENLABS_NATIVE_CUSTOMER_AGENT_ID=
ELEVENLABS_NATIVE_SUPPLIER_AGENT_ID=
ELEVENLABS_PHONE_NUMBER_ID=
ELEVENLABS_WEBHOOK_SECRET=
PACTA_ELEVENLABS_RUNTIME=custom_llm
PACTA_OUTBOUND_CALLS_ENABLED=false

# Models (Vercel OIDC is automatic in deployed environments)
AI_GATEWAY_API_KEY=
PACTA_BRAIN_MODEL=openai/gpt-5.4-nano
PACTA_BRAIN_MODE=
# Backward-compatible model override; prefer PACTA_BRAIN_MODEL.
REDUCER_MODEL=

# Application security
PACTA_DEMO_ACCESS_KEY=

# Optional verification and diagnostics
TEST_DATABASE_URL=
PACTA_BASE_URL=https://pacta.openexp.dev
PACTA_NATIVE_CONFIG_PATH=

# Optional provider experiments; review experiments/README.md before use
ELEVENLABS_TEST_AGENT_ID=
ELEVENLABS_TEST_AGENT_NAME=exploration
PUBLIC_URL=
HOST=0.0.0.0

# Optional mascot browser checks
PACTA_URL=http://127.0.0.1:4185

# Optional direct Twilio REST access; not used by the native ElevenLabs MVP path
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
