{
  "name": "pacta",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --parallel",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:e2e": "pnpm --filter @pacta/web test:e2e",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @pacta/db generate",
    "db:migrate": "pnpm --filter @pacta/db migrate",
    "config:check": "pnpm --filter @pacta/use-case-config check",
    "elevenlabs:provision": "tsx scripts/provision-elevenlabs.ts"
  },
  "devDependencies": {
    "@elevenlabs/elevenlabs-js": "2.58.0",
    "@eslint/js": "9.39.5",
    "@types/node": "26.1.1",
    "eslint": "9.39.5",
    "prettier": "3.9.5",
    "turbo": "2.10.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
