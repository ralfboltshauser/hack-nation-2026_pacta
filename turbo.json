{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "AI_GATEWAY_API_KEY",
    "DATABASE_URL",
    "DIRECT_URL",
    "ELEVENLABS_API_KEY",
    "ELEVENLABS_CUSTOMER_AGENT_ID",
    "ELEVENLABS_NATIVE_CUSTOMER_AGENT_ID",
    "ELEVENLABS_NATIVE_SUPPLIER_AGENT_ID",
    "ELEVENLABS_PHONE_NUMBER_ID",
    "ELEVENLABS_SUPPLIER_AGENT_ID",
    "ELEVENLABS_WEBHOOK_SECRET",
    "NEXT_PUBLIC_PACTA_DEFAULT_CUSTOMER_PHONE",
    "NEXT_PUBLIC_PACTA_DEFAULT_SUPPLIER_PHONES",
    "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_SUPABASE_URL",
    "PACTA_BRAIN_MODE",
    "PACTA_BRAIN_MODEL",
    "PACTA_DEMO_ACCESS_KEY",
    "PACTA_ELEVENLABS_RUNTIME",
    "PACTA_OUTBOUND_CALLS_ENABLED",
    "REDUCER_MODEL",
    "SUPABASE_SECRET_KEY",
    "SUPABASE_STORAGE_BUCKET",
    "TEST_DATABASE_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": ["coverage/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    }
  }
}
